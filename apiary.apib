              "annuncioId": "6825b9d94b0d6f001234cc01"
            }

+ Response 201 (application/json)

        {
          "prenotazione": {
            "_id": "6825bc414b0d6f001234dd01",
            "annuncio": "6825b9d94b0d6f001234cc01",
            "acquirente": "6825bb884b0d6f001234d001",
            "donatore": "6825b53f4b0d6f001234abcd",
            "stato": "ATTIVA",
            "dataPrenotazione": "2026-05-15T11:00:00.000Z"
          },
          "indirizzo": {
            "latitudine": 46.0667,
            "longitudine": 11.1500
          }
        }

+ Response 400 (application/json)

        {
          "error": "annuncioId is required"
        }

+ Response 403 (application/json)

        {
          "error": "Account sospeso"
        }

+ Response 404 (application/json)

        {
          "error": "Annuncio non trovato"
        }

+ Response 409 (application/json)

        {
          "error": "Non puoi prenotare il tuo stesso annuncio"
        }

+ Response 409 (application/json)

        {
          "error": "Oggetto già prenotato"
        }

+ Response 409 (application/json)

        {
          "error": "Oggetto non più disponibile"
        }


              "page": 1,
              "limit": 20,
              "total": 1,
              "pages": 1
            }
          }
        }

### Send message [POST]

+ Request (application/json)
    + Headers

            Authorization: Bearer jwt-token

    + Body

            {
              "testo": "Ciao, quando ci vediamo?"
            }

+ Response 201 (application/json)

        {
          "ok": true,
          "data": {
            "_id": "6825bf6f4b0d6f001234fa11",
            "mittente": "6825bb884b0d6f001234d001",
            "testo": "Ciao, quando ci vediamo?",
            "timestamp": "2026-05-15T11:15:00.000Z",
            "letto": false
          }
        }

+ Response 400 (application/json)

        {
          "ok": false,
          "error": "testo è obbligatorio"
        }

